# ─── MonadDerby Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in values before running testnet mode.

# ── Monad Testnet ────────────────────────────────────────────────────────────
# RPC endpoint (default: https://testnet-rpc.monad.xyz)
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Deployer private key for contract deployment (testnet/chain mode)
# ⚠️  Never commit this file with a real key.
DEPLOYER_PRIVATE_KEY=0xyour_deployer_private_key_here

# Agent wallets (optional — defaults to Anvil keys in local mode only)
AGENT_1_PRIVATE_KEY=0x...
AGENT_2_PRIVATE_KEY=0x...
AGENT_3_PRIVATE_KEY=0x...

# ── Race settings ────────────────────────────────────────────────────────────
# Round duration in seconds (default: 60)
ROUND_DURATION_SECONDS=60

# Randomness mode: full-random | seeded
RACE_RANDOMNESS_MODE=full-random

# Price feed: synthetic | coinbase
PRICE_FEED_MODE=synthetic

# AI execution: disabled | shadow | live
AI_EXECUTION_MODE=disabled

# ── AI API Keys (needed for shadow/live AI mode) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# ── Reown (WalletConnect) ────────────────────────────────────────────────────
# Get a project ID at https://cloud.reown.com
VITE_REOWN_PROJECT_ID=your_reown_project_id_here

# ── Frontend chain config (auto-set by start-demo.sh) ───────────────────────
# VITE_MONAD_CHAIN_ID=10143
# VITE_MONAD_CHAIN_NAME=Monad Testnet
# VITE_MONAD_EXPLORER_URL=https://testnet.monadexplorer.com
